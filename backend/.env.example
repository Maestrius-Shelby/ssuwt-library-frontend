# Django
SECRET_KEY='your-secret-key-here-change-in-production'

# Database
DB_NAME='ssuwt_library_db'
DB_USER='postgres'
DB_PASSWORD='your_db_password_here'
HOST_DB='localhost'
PORT_DB='5432'
DEBUG='True'
ENGINE_DB='django.db.backends.postgresql_psycopg2'

# URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# External API (e-library)
ELIBRARY_LOGIN='your_login_here'
ELIBRARY_PASSWORD='your_password_here'

# Django superuser
DJANGO_SUPERUSER_USERNAME='admin'
DJANGO_SUPERUSER_PASSWORD='your_admin_password_here'

# Database URL (for Docker)
DATABASE_URL=postgres://postgres:your_db_password_here@postgres-db:5432/ssuwt_library_db